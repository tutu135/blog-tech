const markup = icons[name] ?? icons.smile;
---

<svg
  class:list={['icon', className]}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-label={label}
  aria-hidden={label ? undefined : 'true'}
  role={label ? 'img' : undefined}
  set:html={markup}
/>
