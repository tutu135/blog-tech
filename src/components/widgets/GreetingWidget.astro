---
import { dashboard, site } from '../../data/site';
---

<section id="hello" class="greeting-widget glass-panel tilt-card">
  <img src={site.avatar} alt="" class="greeting-avatar" width="150" height="150" />
  <div class="greeting-copy">
    <p>{dashboard.greeting}</p>
    <h1>
      I'm <span>{site.owner}</span>, Nice to meet you!
    </h1>
  </div>
</section>

<style>
  .greeting-widget {
    display: grid;
    min-height: 300px;
    place-items: center;
    padding: 32px 34px;
    text-align: center;
  }

  .greeting-avatar {
    position: relative;
    z-index: 1;
    width: 142px;
    height: 142px;
    margin-bottom: 20px;
    border-radius: 50%;
    box-shadow: 0 18px 42px rgba(76, 112, 100, 0.15);
  }

  .greeting-copy {
    position: relative;
    z-index: 1;
  }

  .greeting-copy p {
    margin-bottom: 8px;
    color: var(--color-ink-strong);
    font-size: 26px;
    font-weight: 700;
    line-height: 1.2;
  }

  .greeting-copy h1 {
    max-width: 320px;
    color: var(--color-ink-strong);
    font-size: 25px;
    font-weight: 700;
    line-height: 1.45;
  }

  .greeting-copy span {
    color: var(--color-accent-strong);
    font-size: 34px;
  }

  @media (max-width: 760px) {
    .greeting-widget {
      min-height: 250px;
    }

    .greeting-copy p,
    .greeting-copy h1 {
      font-size: 22px;
    }
  }
</style>
