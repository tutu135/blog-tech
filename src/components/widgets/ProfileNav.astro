---
import Icon from '../ui/Icon.astro';
import { site } from '../../data/site';
---

<aside class="profile-nav glass-panel tilt-card">
  <div class="profile-head">
    <img src={site.avatar} alt="" class="profile-avatar" width="52" height="52" />
    <div class="profile-title">
      <strong>{site.name}</strong>
      <span>{site.status}</span>
    </div>
  </div>

  <div class="nav-kicker">GENERAL</div>

  <nav class="nav-list" aria-label="站点导航">
    {site.navItems.map((item) => (
      <a class:list={['nav-item', item.active && 'is-active']} href={item.href}>
        <Icon name={item.icon} />
        <span>{item.label}</span>
      </a>
    ))}
  </nav>
</aside>

<style>
  .profile-nav {
    width: 100%;
    padding: 30px;
  }

  .profile-head {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 32px;
  }

  .profile-avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    box-shadow: 0 10px 24px rgba(62, 95, 88, 0.14);
  }

  .profile-title {
    display: flex;
    min-width: 0;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
  }

  .profile-title strong {
    color: var(--color-ink-strong);
    font-size: 23px;
    line-height: 1.2;
  }

  .profile-title span {
    color: var(--color-accent-strong);
    font-size: 14px;
    font-weight: 700;
  }

  .nav-kicker {
    position: relative;
    z-index: 1;
    margin-bottom: 12px;
    color: var(--color-muted);
    font-size: 14px;
    font-weight: 700;
  }

  .nav-list {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 12px;
  }

  .nav-item {
    display: flex;
    min-height: 58px;
    align-items: center;
    gap: 18px;
    padding: 0 24px;
    border: 1px solid transparent;
    border-radius: 30px;
    color: var(--color-muted);
    font-size: 18px;
    font-weight: 700;
    text-decoration: none;
    transition: background 0.25s ease, color 0.25s ease, transform 0.25s ease;
  }

  .nav-item:hover,
  .nav-item.is-active {
    border-color: rgba(255, 255, 255, 0.68);
    background: rgba(255, 255, 255, 0.66);
    color: var(--color-ink);
    transform: translateX(2px);
  }

  .nav-item.is-active .icon {
    color: var(--color-accent);
  }

  @media (max-width: 900px) {
    .profile-nav {
      padding: 22px;
    }

    .nav-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .nav-item {
      min-height: 50px;
      padding: 0 16px;
      font-size: 15px;
    }
  }

  @media (max-width: 560px) {
    .nav-list {
      grid-template-columns: 1fr;
    }
  }
</style>
