---
import { dashboard } from '../../data/site';
---

<section id="recommend" class="recommend-widget glass-panel tilt-card">
  <span class="widget-title">随机推荐</span>
  <div class="recommend-body">
    <div class="cover">DB</div>
    <div>
      <strong>{dashboard.recommendation.title}</strong>
      <p>{dashboard.recommendation.summary}</p>
      <span>{dashboard.recommendation.meta}</span>
    </div>
  </div>
</section>

<style>
  .recommend-widget {
    min-height: 176px;
    padding: 28px;
  }

  .widget-title,
  .recommend-body {
    position: relative;
    z-index: 1;
  }

  .widget-title {
    display: block;
    margin-bottom: 16px;
    color: var(--color-muted);
    font-size: 15px;
    font-weight: 700;
  }

  .recommend-body {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .cover {
    display: grid;
    width: 64px;
    height: 52px;
    flex: 0 0 auto;
    place-items: center;
    border-radius: 10px;
    background: #111716;
    color: white;
    font-size: 18px;
    font-weight: 700;
  }

  strong {
    color: var(--color-ink);
    font-size: 16px;
  }

  p {
    margin: 10px 0 8px;
    color: var(--color-muted);
    font-size: 13px;
    line-height: 1.45;
  }

  span {
    color: var(--color-muted);
    font-size: 13px;
  }
</style>
