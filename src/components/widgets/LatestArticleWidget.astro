---
interface ArticleItem {
  id: string;
  data: {
    title: string;
    summary: string;
    pubDate: Date;
    column: { id: string };
  };
}

interface Props {
  article?: ArticleItem;
}

const { article } = Astro.props;
const href = article ? `/columns/${article.data.column.id}/${article.id}/` : '#recent';
const date = article ? article.data.pubDate.toISOString().slice(0, 10).replace(/-/g, '/') : '';
---

<a id="recent" href={href} class="latest-widget glass-panel tilt-card">
  <span class="widget-title">最新文章</span>
  {article ? (
    <div class="latest-body">
      <img src="/assets/sticker-board.svg" alt="" width="64" height="64" />
      <div>
        <strong>{article.data.title}</strong>
        <p>{article.data.summary}</p>
        <time datetime={article.data.pubDate.toISOString()}>{date}</time>
      </div>
    </div>
  ) : (
    <p class="empty">还没有文章</p>
  )}
</a>

<style>
  .latest-widget {
    display: block;
    min-height: 164px;
    padding: 28px;
    color: inherit;
    text-decoration: none;
  }

  .widget-title {
    position: relative;
    z-index: 1;
    display: block;
    margin-bottom: 14px;
    color: var(--color-muted);
    font-size: 15px;
    font-weight: 700;
  }

  .latest-body {
    position: relative;
    z-index: 1;
    display: flex;
    gap: 14px;
    align-items: center;
  }

  .latest-body img {
    width: 58px;
    height: 58px;
    flex: 0 0 auto;
    border-radius: 14px;
    object-fit: cover;
  }

  .latest-body strong {
    display: -webkit-box;
    overflow: hidden;
    color: var(--color-ink);
    font-size: 16px;
    line-height: 1.35;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 1;
  }

  .latest-body p {
    display: -webkit-box;
    overflow: hidden;
    margin: 4px 0 10px;
    color: var(--color-muted);
    font-size: 13px;
    line-height: 1.45;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .latest-body time,
  .empty {
    color: var(--color-muted);
    font-size: 13px;
    font-weight: 700;
  }
</style>
