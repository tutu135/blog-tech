---
import { site } from '../../data/site';
---

<section class="hero-sticker glass-panel" aria-label="视觉横幅">
  <img src={site.banner} alt="" width="620" height="300" />
</section>

<style>
  .hero-sticker {
    min-height: 168px;
    border-radius: 34px;
    background: rgba(255, 255, 255, 0.42);
  }

  .hero-sticker img {
    width: 100%;
    height: 100%;
    min-height: 168px;
    object-fit: cover;
  }
</style>
