---
import Icon from '../ui/Icon.astro';
import { dashboard } from '../../data/site';

const progress = `${dashboard.music.progress}%`;
---

<section class="music-widget glass-panel" aria-label="音乐">
  <Icon name="music" />
  <div class="music-main">
    <span>{dashboard.music.title}</span>
    <div class="music-bar" style={`--progress: ${progress}`} />
  </div>
  <button type="button" aria-label="暂停音乐">
    <Icon name="pause" />
  </button>
</section>

<style>
  .music-widget {
    display: flex;
    min-height: 74px;
    align-items: center;
    gap: 16px;
    padding: 14px 18px;
    border-radius: 22px;
  }

  .music-widget > .icon {
    position: relative;
    z-index: 1;
    color: var(--color-accent);
  }

  .music-main {
    position: relative;
    z-index: 1;
    min-width: 0;
    flex: 1;
  }

  .music-main span {
    display: block;
    margin-bottom: 8px;
    color: var(--color-muted);
    font-size: 15px;
    font-weight: 700;
  }

  .music-bar {
    height: 8px;
    overflow: hidden;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.66);
  }

  .music-bar::before {
    content: '';
    display: block;
    width: var(--progress);
    height: 100%;
    border-radius: inherit;
    background: var(--color-accent);
  }

  button {
    position: relative;
    z-index: 1;
    display: grid;
    width: 48px;
    height: 48px;
    flex: 0 0 auto;
    place-items: center;
    border: 0;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.78);
    color: var(--color-accent);
    cursor: pointer;
  }
</style>
