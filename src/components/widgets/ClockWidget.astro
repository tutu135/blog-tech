---
---

<section class="clock-widget glass-panel" aria-label="当前时间">
  <time data-clock-time>--:--</time>
</section>

<script>
  function mountClockWidgets() {
    const nodes = Array.from(document.querySelectorAll('[data-clock-time]'));
    if (!nodes.length) return;

    const tick = () => {
      const now = new Date();
      const value = new Intl.DateTimeFormat('zh-CN', {
        hour: '2-digit',
        minute: '2-digit',
        hour12: false,
      }).format(now);
      nodes.forEach((node) => {
        node.textContent = value;
        node.setAttribute('datetime', now.toISOString());
      });
    };

    tick();
    if (!(window as any).__lvyClockTimer) {
      (window as any).__lvyClockTimer = window.setInterval(() => {
        document.querySelectorAll('[data-clock-time]').forEach((node) => {
          const now = new Date();
          node.textContent = new Intl.DateTimeFormat('zh-CN', {
            hour: '2-digit',
            minute: '2-digit',
            hour12: false,
          }).format(now);
          node.setAttribute('datetime', now.toISOString());
        });
      }, 1000);
    }
  }

  mountClockWidgets();
  document.addEventListener('astro:page-load', mountClockWidgets);
</script>

<style>
  .clock-widget {
    display: grid;
    min-height: 132px;
    place-items: center;
    padding: 14px;
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.48);
  }

  .clock-widget time {
    display: grid;
    width: 100%;
    min-height: 92px;
    place-items: center;
    border-radius: 22px;
    background: rgba(205, 215, 213, 0.52);
    color: #2c4b4e;
    font-family: var(--font-sans);
    font-size: 58px;
    font-weight: 400;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 420px) {
    .clock-widget time {
      font-size: 48px;
    }
  }
</style>
