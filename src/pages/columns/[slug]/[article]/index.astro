---
import { getCollection, render, getEntry } from 'astro:content';
import Layout from '../../../../layouts/Layout.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  const paths = [];
  for (const article of articles) {
    paths.push({
      params: { slug: article.data.column.id, article: article.id },
      props: { article },
    });
  }
  return paths;
}

const { article } = Astro.props;
const column = await getEntry(article.data.column);
const { Content } = await render(article);
---

<Layout title={`${article.data.title} · lvy-tech`}>
  <a href={`/columns/${column.id}/`} class="back-link">&larr; 返回 {column.data.title}</a>

  <article class="card article-card" transition:name={`article-${article.id}`}>
    <div class="title-row">
      <span class="title">{article.data.title}</span>
      <span class="year">{article.data.pubDate.toISOString().slice(0, 10)}</span>
    </div>
    <div class="prose">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .article-card {
    display: block;
    padding: 36px 40px;
  }
  .article-card:hover {
    transform: none;
  }
  .title-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }
  .title {
    font-size: 24px;
    font-weight: 700;
    color: #213128;
  }
  .year {
    font-size: 14px;
    color: #7c8b81;
  }
  .prose {
    font-size: 15px;
    line-height: 1.85;
    color: #36473d;
  }
  .prose :global(p) {
    margin-bottom: 16px;
  }
</style>
