---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import GlassCard from '../../../components/GlassCard.astro';

export async function getStaticPaths() {
  const columns = await getCollection('columns');
  return columns.map((column) => ({
    params: { slug: column.id },
    props: { column },
  }));
}

const { column } = Astro.props;
const allArticles = await getCollection('articles');
const articles = allArticles
  .filter((a) => a.data.column.id === column.id)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title={`${column.data.title} · lvy-tech`}>
  <a href="/" class="back-link">&larr; 返回专栏</a>
  <div class="page-title">{column.data.title}</div>
  <div class="page-sub">{column.data.summary}</div>

  <div class="grid">
    {articles.map((article) => (
      <GlassCard
        href={`/columns/${column.id}/${article.id}/`}
        icon={column.data.icon}
        title={article.data.title}
        meta={article.data.pubDate.toISOString().slice(0, 10)}
        description={article.data.summary}
        transitionName={`article-${article.id}`}
      />
    ))}
  </div>
</Layout>
