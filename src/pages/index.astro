---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { articles, navItems, projects, site, skills } from '@/data/site';

const uniqueTags = Array.from(new Set(articles.flatMap((article) => article.tags)));
---

<BaseLayout title={`${site.name} | Personal Blog`} description={site.description}>
  <div class="site-shell">
    <header class="top-nav" aria-label="Primary navigation">
      <a class="brand" href="#about" aria-label={`${site.name} home`}>
        <span class="brand-mark" aria-hidden="true"></span>
        <span>{site.name}</span>
      </a>
      <nav class="nav-links" aria-label="Sections">
        {navItems.map((item) => (
          <a class="nav-link" href={item.href} data-nav-link={item.href.slice(1)}>{item.label}</a>
        ))}
      </nav>
      <div class="nav-meta" aria-label="Site metadata">
        <span>{site.location}</span>
        <span class="language-pill">{site.language}</span>
      </div>
    </header>

    <main>
      <section id="about" class="hero" data-section="about" aria-label="Introduction">
        <div class="hero-visual" aria-hidden="true">
          <span class="shape shape-circle"></span>
          <span class="shape shape-ring"></span>
          <span class="shape shape-line"></span>
          <span class="shape shape-triangle"></span>
        </div>
        <h1 class="hero-title">{site.title}</h1>
        <a class="scroll-cue" href="#skills" aria-label="Scroll to skills">
          <span>Scroll to explore</span>
          <span class="scroll-dot" aria-hidden="true"></span>
        </a>
      </section>

      <section id="skills" class="section" data-section="skills" aria-labelledby="skills-title">
        <div class="section-heading reveal">
          <div>
            <p class="section-kicker">Capability</p>
            <h2 id="skills-title" class="section-title">专业技能</h2>
          </div>
          <p class="section-copy">先用占位内容描述能力边界。每张卡片在滚动时逐张进入，保持一页式叙事的节奏。</p>
        </div>
        <div class="skills-grid">
          {skills.map((skill, index) => (
            <article class="glass-card skill-card reveal tilt-card" style={`--delay: ${index * 90}ms`}>
              <span class="skill-index">{String(index + 1).padStart(2, '0')}</span>
              <h3>{skill.name}</h3>
              <p>{skill.summary}</p>
              <div class="tag-row" aria-label={`${skill.name} tags`}>
                {skill.tags.map((tag) => <span class="tag">{tag}</span>)}
              </div>
            </article>
          ))}
        </div>
      </section>

      <section id="projects" class="section" data-section="projects" aria-labelledby="projects-title">
        <div class="section-heading reveal">
          <div>
            <p class="section-kicker">Selected Work</p>
            <h2 id="projects-title" class="section-title">项目展示</h2>
          </div>
          <p class="section-copy">项目先用占位数据。大卡片承担主视觉，信息保持短句，之后可以替换成真实项目。</p>
        </div>
        <div class="projects-list">
          {projects.map((project, index) => (
            <article
              class="glass-card project-card reveal tilt-card"
              data-number={String(index + 1).padStart(2, '0')}
              style={`--delay: ${index * 110}ms`}
            >
              <h3>{project.title}</h3>
              <p>{project.summary}</p>
              <div class="tag-row" aria-label={`${project.title} tags`}>
                {project.tags.map((tag) => <span class="tag">{tag}</span>)}
              </div>
              <span class="project-meta">{project.year}</span>
            </article>
          ))}
        </div>
      </section>

      <section id="writing" class="section" data-section="writing" aria-labelledby="writing-title">
        <div class="section-heading reveal">
          <div>
            <p class="section-kicker">Writing</p>
            <h2 id="writing-title" class="section-title">文章记录</h2>
          </div>
          <p class="section-copy">文章区保留简单搜索和标签筛选，首版仍然是轻量静态交互，不引入后台或数据库。</p>
        </div>
        <div class="glass-card writing-panel reveal">
          <div class="writing-tools">
            <label>
              <span class="section-kicker">Search</span>
              <input class="search-field" type="search" placeholder="搜索标题、摘要或标签" data-search />
            </label>
            <div class="filter-row" aria-label="Article filters">
              <button class="filter-button is-active" type="button" data-filter="all">All</button>
              {uniqueTags.map((tag) => <button class="filter-button" type="button" data-filter={tag}>{tag}</button>)}
            </div>
          </div>
          <div class="article-list" data-article-list>
            {articles.map((article, index) => (
              <a
                class="article-card reveal"
                href={`/posts/${article.slug}`}
                data-article
                data-title={article.title}
                data-summary={article.summary}
                data-tags={article.tags.join(' ')}
                style={`--delay: ${index * 90}ms`}
              >
                <time class="article-date" datetime={article.date}>{article.date}</time>
                <span>
                  <h3>{article.title}</h3>
                  <p>{article.summary}</p>
                </span>
                <span class="article-arrow" aria-hidden="true">→</span>
              </a>
            ))}
          </div>
          <p class="empty-state" data-empty-state>没有找到匹配的文章。</p>
        </div>
      </section>
    </main>
  </div>

  <script>
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const navLinks = Array.from(document.querySelectorAll('[data-nav-link]'));
    const sections = Array.from(document.querySelectorAll<HTMLElement>('[data-section]'));
    const revealItems = Array.from(document.querySelectorAll('.reveal'));
    const heroVisual = document.querySelector<HTMLElement>('.hero-visual');

    const setActiveSection = (id: string | null) => {
      navLinks.forEach((link) => {
        link.classList.toggle('is-active', link.getAttribute('data-nav-link') === id);
      });
    };

    const updateActiveSection = () => {
      const marker = window.innerHeight * 0.38;
      let current = sections[0];

      sections.forEach((section) => {
        const rect = section.getBoundingClientRect();
        if (rect.top <= marker && rect.bottom >= marker) {
          current = section;
        }
      });

      setActiveSection(current?.getAttribute('data-section') || 'about');
    };

    updateActiveSection();
    window.addEventListener('scroll', updateActiveSection, { passive: true });

    if ('IntersectionObserver' in window) {
      const sectionObserver = new IntersectionObserver((entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
        if (visible) updateActiveSection();
      }, { threshold: [0.35, 0.55, 0.75] });

      sections.forEach((section) => sectionObserver.observe(section));

      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            revealObserver.unobserve(entry.target);
          }
        });
      }, { rootMargin: '0px 0px -12% 0px', threshold: 0.12 });

      revealItems.forEach((item) => revealObserver.observe(item));
    } else {
      revealItems.forEach((item) => item.classList.add('is-visible'));
    }

    if (!reduceMotion && heroVisual) {
      window.addEventListener('pointermove', (event) => {
        const x = event.clientX - window.innerWidth / 2;
        const y = event.clientY - window.innerHeight / 2;
        heroVisual.style.setProperty('--mx', `${x}px`);
        heroVisual.style.setProperty('--my', `${y}px`);
      }, { passive: true });
    }

    if (!reduceMotion) {
      document.querySelectorAll<HTMLElement>('.tilt-card').forEach((card) => {
        card.addEventListener('pointermove', (event) => {
          const rect = card.getBoundingClientRect();
          const x = (event.clientX - rect.left) / rect.width - 0.5;
          const y = (event.clientY - rect.top) / rect.height - 0.5;
          card.style.setProperty('--tilt-x', `${y * -4}deg`);
          card.style.setProperty('--tilt-y', `${x * 5}deg`);
        });
        card.addEventListener('pointerleave', () => {
          card.style.setProperty('--tilt-x', '0deg');
          card.style.setProperty('--tilt-y', '0deg');
        });
      });
    }

    const search = document.querySelector<HTMLInputElement>('[data-search]');
    const filterButtons = Array.from(document.querySelectorAll('[data-filter]'));
    const articles = Array.from(document.querySelectorAll<HTMLElement>('[data-article]'));
    const emptyState = document.querySelector('[data-empty-state]');
    let activeFilter = 'all';

    const normalize = (value: string) => value.toLowerCase().trim();

    const applyArticleFilters = () => {
      const query = normalize(search?.value || '');
      let visibleCount = 0;

      articles.forEach((article) => {
        const haystack = normalize([
          article.getAttribute('data-title'),
          article.getAttribute('data-summary'),
          article.getAttribute('data-tags'),
        ].join(' '));
        const tags = article.getAttribute('data-tags') || '';
        const matchesQuery = !query || haystack.includes(query);
        const matchesFilter = activeFilter === 'all' || tags.includes(activeFilter);
        const isVisible = matchesQuery && matchesFilter;
        article.hidden = !isVisible;
        if (isVisible) visibleCount += 1;
      });

      emptyState?.classList.toggle('is-visible', visibleCount === 0);
    };

    search?.addEventListener('input', applyArticleFilters);
    filterButtons.forEach((button) => {
      button.addEventListener('click', () => {
        activeFilter = button.getAttribute('data-filter') || 'all';
        filterButtons.forEach((item) => item.classList.toggle('is-active', item === button));
        applyArticleFilters();
      });
    });
  </script>
</BaseLayout>
