---
import BaseLayout from './BaseLayout.astro';
import { site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${site.name} · ${site.title}`,
  description = site.description,
} = Astro.props;
---

<BaseLayout title={title} description={description}>
  <main class="dashboard-page">
    <slot />
  </main>
</BaseLayout>
