---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'lvy-tech personal technical notes.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@600&family=Plus+Jakarta+Sans:wght@400;500;700&display=swap" rel="stylesheet" />
  <ClientRouter />
</head>
<body>
  <slot />

  <script>
    function attachCardTilt() {
      const cards = document.querySelectorAll('.tilt-card, .card:not(.article-card)');
      const maxTilt = 7;

      cards.forEach((card) => {
        if (!(card instanceof HTMLElement) || card.dataset.tiltReady === 'true') return;
        card.dataset.tiltReady = 'true';

        card.addEventListener('mousemove', (e) => {
          if (!(e instanceof MouseEvent)) return;
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          const px = (x / rect.width) * 100;
          const py = (y / rect.height) * 100;
          card.style.setProperty('--mx', px + '%');
          card.style.setProperty('--my', py + '%');

          const cx = x / rect.width - 0.5;
          const cy = y / rect.height - 0.5;
          const rotateY = cx * maxTilt * 2;
          const rotateX = -cy * maxTilt * 2;
          card.style.transform = `perspective(800px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) translateY(-4px) scale(1.015)`;
        });

        card.addEventListener('mouseleave', () => {
          card.style.transform = 'perspective(800px) rotateX(0deg) rotateY(0deg) translateY(0) scale(1)';
        });
      });
    }

    attachCardTilt();
    document.addEventListener('astro:page-load', attachCardTilt);
  </script>
</body>
</html>
